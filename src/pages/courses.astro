---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const grouped = Object.entries(Object.groupBy(posts.filter((post) => post.data.course), (post) => post.data.course!));
---
<BaseLayout title="课程">
  <header class="page-head shell"><p class="eyebrow">COURSE INDEX</p><h1>课程索引</h1><p>按课程聚合学习过程，而不是让笔记散落在时间线里。</p></header>
  <div class="shell courses">{grouped.map(([course, items], index) => <section id={course}><div class="course-title"><span>{String(index + 1).padStart(2, '0')}</span><h2>{course}</h2><small>{items?.length} 篇</small></div><div>{items?.map((post) => <a href={`/blog/${post.id}`}><time>{post.data.date.toLocaleDateString('zh-CN')}</time><strong>{post.data.title}</strong><span>→</span></a>)}</div></section>)}</div>
</BaseLayout>
<style>
  .page-head { padding: 76px 0 48px; }
  h1 { margin: 0; font: 650 clamp(2.7rem, 7vw, 5rem)/1.1 ui-serif, Georgia, "Noto Serif SC", serif; }
  .page-head > p:last-child { color: var(--muted); }
  .courses section { scroll-margin-top: 90px; display: grid; grid-template-columns: 280px 1fr; gap: 56px; padding: 38px 0; border-top: 1px solid var(--line); }
  .course-title { display: grid; grid-template-columns: 32px 1fr; align-items: baseline; }
  .course-title span { color: var(--warm); font: .75rem ui-monospace, monospace; }
  .course-title h2 { margin: 0; font: 600 1.45rem/1.3 ui-serif, Georgia, "Noto Serif SC", serif; }
  .course-title small { grid-column: 2; color: var(--muted); }
  section a { display: grid; grid-template-columns: 110px 1fr auto; gap: 20px; padding: 12px 0; border-bottom: 1px solid var(--line); }
  section time { color: var(--muted); font-size: .76rem; }
  section strong { font-size: .9rem; }
  @media (max-width: 720px) { .courses section { grid-template-columns: 1fr; gap: 18px; } section a { grid-template-columns: 1fr auto; } section time { grid-column: 1 / -1; } }
</style>
